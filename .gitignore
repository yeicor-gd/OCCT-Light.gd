# Ignore generated autowrapper source files (regenerated by OCCT-Light.gd-autowrapper)
/src/autowrapper/

# Ignore generated Godot XML documentation (regenerated by autowrapper)
/doc_classes/*.xml
/doc_classes/*.xml.uid

# Ignore generated GDScript test files (regenerated by autowrapper)
/demo/tests/test_Occtl*.gd
/demo/tests/test_Occtl*.gd.uid
/demo/tests/test_Ocl*.gd
/demo/tests/test_Ocl*.gd.uid
/demo/tests/index.gd
/demo/tests/index.gd.uid

# Build artifacts.
/build/

# IDEs
/.idea/
/.vscode/
/compile_commands.json
/.cache/

# VCPKG
/vcpkg_ports/*/.last_build
/vcpkg_installed/

# Autowrapper temporary build error files
/.build_errors_*.txt

# Godot auto generated files
/demo/.godot/
/demo/addons/*/*
!/demo/addons/*/gdext.gdextension*
/demo/exports
