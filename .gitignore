# Ignore generated autowrapper source files (regenerated by OCCT-Light.gd-autowrapper)
/src/autowrapper/

# Ignore generated Godot XML documentation (regenerated by autowrapper)
/doc_classes/autowrapper/

# Ignore generated GDScript test files (regenerated by autowrapper)
/demo/tests/autowrapper/

# Build artifacts.
/build/

# IDEs
/.idea/
/.vscode/
/compile_commands.json
/.cache/

# VCPKG
/vcpkg_ports/*/.last_build
/vcpkg_installed/

# Godot auto generated files
/demo/.godot/
/demo/addons/*/*
!/demo/addons/*/gdext.gdextension*
/demo/exports
